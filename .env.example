# Copie para .env e preencha. O .env NUNCA vai pro git (está no .gitignore).

# Banco (VPS roda PostgreSQL 12, localhost only)
DATABASE_URL=postgresql://dividendo_bot_user:SENHA_AQUI@localhost:5432/dividendo_bot

# Auth JWT (Agente 1)
JWT_SECRET=gere_uma_string_aleatoria_longa_aqui
JWT_EXPIRE_MINUTES=1440   # 24 horas

# Usuário inicial (só usado pelo script create_user.py)
ADMIN_USERNAME=isaac
ADMIN_PASSWORD=sua_senha_aqui

# Dados externos (Fase 1 — brapi.dev). Vazio = fallback desativado.
BRAPI_TOKEN=

# App
SCAN_HORA=7                 # hora do scan automático (Agente 2)
AMBIENTE=production
